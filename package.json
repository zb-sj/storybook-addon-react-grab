{
  "name": "@zigbang/storybook-addon-react-grab",
  "version": "0.1.0",
  "description": "Storybook addon: grab story elements into your clipboard for AI agents, enriched with story context.",
  "publishConfig": { "access": "public" },
  "license": "MIT",
  "author": "Jeong, Sejun",
  "type": "module",
  "keywords": [
    "storybook",
    "storybook-addon",
    "storybook-addons",
    "addon",
    "react-grab",
    "react",
    "ai",
    "clipboard",
    "copy",
    "devtools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zigbang/storybook-addon-react-grab.git"
  },
  "homepage": "https://github.com/zigbang/storybook-addon-react-grab#readme",
  "bugs": "https://github.com/zigbang/storybook-addon-react-grab/issues",
  "exports": {
    "./manager": "./dist/manager.js",
    "./preview": { "types": "./dist/preview.d.ts", "default": "./dist/preview.js" },
    "./package.json": "./package.json"
  },
  "files": ["dist/**/*", "manager.js", "preview.js", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "prepare": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-grab": "*",
    "storybook": ">=9"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/react": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-grab": "latest",
    "storybook": "^9.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
